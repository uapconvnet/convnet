<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
             xmlns:behaviors="clr-namespace:Convnet.Common;assembly=Convnet"
             xmlns:c="clr-namespace:Convnet.Common"
             xmlns:props="clr-namespace:Convnet.Properties"
             xmlns:vm="clr-namespace:Convnet.PageViewModels"
             x:Class="Convnet.PageViews.EditPageView"
             x:DataType="vm:EditPageViewModel"
             Loaded="UserControl_Loaded"
             IsTabStop="True">
            
  <Grid x:Name="grid" Background="{DynamicResource BackgroundBrush}">
    <Grid.ColumnDefinitions>
      <ColumnDefinition MinWidth="200" MaxWidth="800"/>
      <ColumnDefinition Width="*" MinWidth="200"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="28" MinHeight="28"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <!-- <Image x:Name="ImageStatusDefinition" Grid.Column="0" Grid.Row="0" /> -->
    <TextBlock Background="{DynamicResource BackgroundBrushLight}" Foreground="{DynamicResource TextBrush}" FontSize="17" FontWeight="DemiBold" Text="Definition" TextAlignment="Center" Grid.Column="0" Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="2,2,4,2" Padding="4"/>
    <TextBlock Background="{DynamicResource BackgroundBrushLight}" Foreground="{DynamicResource TextBrush}" FontSize="17" FontWeight="DemiBold" Text="Scripts" TextAlignment="Center" Grid.Column="1" Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0,2,2,2" Padding="4"/>
    <c:DefinitionEditor x:Name="EditorDefinition" IsTabStop="True" TabIndex="0" Focusable="True" Definition="{Binding Definition, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" IsVisible="True" Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource TextBrush}" Grid.Column="0" Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ShowLineNumbers="True" TextLocation="{Binding TextLocationDefinition, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" VerticalOffset="{Binding VerticalOffsetDefinition, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" CaretOffset="{Binding CaretOffsetDefinition, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" SelectionStart="{Binding SelectionStartDefinition, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" SelectionLength="{Binding SelectionLengthDefinition, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Padding="2" Margin="0,0,6,0" />
    <GridSplitter DragCompleted="GridSplitter_DragCompleted" Grid.Column="0" HorizontalAlignment="Right" Grid.Row="0" Grid.RowSpan="2" VerticalAlignment="Stretch" IsTabStop="False" Focusable="False" Width="0" Background="{DynamicResource BackgroundBrushLight}" Margin="0,28,0,0" ResizeDirection="Columns"/>
     <Grid x:Name="subgrid" Background="{DynamicResource BackgroundBrush}" Grid.Column="1" Grid.Row="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="56" MinHeight="28" MaxHeight="56"/>
      </Grid.RowDefinitions>
      <c:ScriptEditor x:Name="EditorScript" IsTabStop="True" TabIndex="1" Focusable="True" Script="{Binding Script, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" IsVisible="True" Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource TextBrush}" Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ShowLineNumbers="True" TextLocation="{Binding TextLocationScript, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" VerticalOffset="{Binding VerticalOffsetScript, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" CaretOffset="{Binding CaretOffsetScript, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" SelectionStart="{Binding SelectionStartScript, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" SelectionLength="{Binding SelectionLengthScript, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Padding="2" Margin="0,0,4,0"/>
      <GridSplitter DragCompleted="GridSplitterOutput_DragCompleted" Grid.Column="0" HorizontalAlignment="Stretch" Grid.Row="0" Grid.RowSpan="1" VerticalAlignment="Bottom" IsTabStop="False" Focusable="False" Height="0" Background="{DynamicResource BackgroundBrushLight}" Margin="0,28,0,0" ResizeDirection="Rows"/>
      <c:DefinitionEditor x:Name="EditorOutput" IsReadOnly="True" IsTabStop="False" TabIndex="2" Focusable="False" Definition="{Binding Output, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" IsVisible="True" Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource TextBrush}" Grid.Column="0" Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ShowLineNumbers="False" Padding="2" Margin="0,0,6,0" />
    </Grid>
  </Grid>
</UserControl>
